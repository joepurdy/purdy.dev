---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const { title, description, noindex } = Astro.props;
const siteTitle = "Purdy.dev";
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const pageDescription = description || "Joe Purdy's personal site";
---

<!doctype html>
<html lang="en" class="bg-bg text-text">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={pageDescription} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{pageTitle}</title>
    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteTitle}
      href="/rss.xml"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="min-h-screen flex flex-col max-w-2xl mx-auto px-4 sm:px-6">
    <Header />
    <main class="flex-1 py-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>

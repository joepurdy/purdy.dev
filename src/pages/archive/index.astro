---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostListItem from "../../components/PostListItem.astro";

const posts = await getCollection("posts", ({ data }) => !data.draft && data.archived);
const sorted = posts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Archive" noindex>
  <h1 class="text-2xl font-bold mb-2">Archive</h1>
  <p class="text-text-muted text-sm mb-6">
    These posts contain outdated or irrelevant information and are kept for historical reference only.
  </p>
  <div class="space-y-0 divide-y divide-border">
    {sorted.map((post) => (
      <PostListItem
        title={post.data.title}
        date={post.data.date}
        description={post.data.description}
        url={`/posts/${post.data.slug}/`}
      />
    ))}
  </div>
</BaseLayout>
